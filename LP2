from flask import Flask

app = Flask(__name__)

@app.route('/')

def binary_search():

    arr = [1,2,3,4,5,6,7,8,9]
    key = 5

    low = 0
    high = len(arr)-1

    while low <= high:

        mid = (low + high)//2

        if arr[mid] == key:
            return "Element Found"

        elif arr[mid] < key:
            low = mid + 1

        else:
            high = mid - 1

    return "Element Not Found"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8080)
